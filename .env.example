MONGO_URI=mongodb://mongo:27017
MONGO_DB=knowledge_base
JWT_SECRET=change-this-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
ZERO_COST_MODE=true
AI_PROVIDER=local
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
EMBEDDING_PROVIDER=fastembed
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=128
FASTEMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2
SENTENCE_TRANSFORMER_MODEL=sentence-transformers/all-MiniLM-L6-v2
TRANSFORMERS_SUMMARY_MODEL=google/flan-t5-small
TRANSFORMERS_DEVICE=-1
HF_HOME=/app/model-cache
TRANSFORMERS_CACHE=/app/model-cache/transformers
HF_HUB_CACHE=/app/model-cache/hub
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.1
FILE_STORAGE_DIR=/app/uploads
STORAGE_BACKEND=local
S3_ENDPOINT_URL=http://minio:9000
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET=knowledge-base-uploads
S3_REGION=us-east-1
S3_SECURE_URLS=false
MAX_UPLOAD_SIZE_MB=25
MAX_DOCUMENT_CHARS=200000
ANALYSIS_EXECUTION_MODE=background
ANALYSIS_WORKER_POLL_SECONDS=2
PASSWORD_RESET_TOKEN_MINUTES=30
RETURN_PASSWORD_RESET_TOKEN=true
RATE_LIMIT_BACKEND=redis
REDIS_URL=redis://valkey:6379/0
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
CADDY_SITE_ADDRESS=:80
